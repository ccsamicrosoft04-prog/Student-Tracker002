DATABASE_URL="mysql://root@localhost:3306/student_tracker"
# Local Laragon Settings
DB_HOST="localhost"
DB_PORT=3306
DB_USER="root"
DB_PASSWORD=""
DB_NAME="attendance_db"
# Timezone Settings
APP_TIMEZONE="Asia/Manila"
TZ="Asia/Manila"

# Next Auth (if you are using it for login)
NEXTAUTH_SECRET="any-random-string-here"
NEXTAUTH_URL="http://localhost:3000"
PRISMA_CLI_BINARY_TARGETS="windows"
# Replace 'root' with your Laragon MySQL username
# Replace 'password' with your password (leave empty if no password)
# 'student_tracker' is the name of the database in HeidiSQL

