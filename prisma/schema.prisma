// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  
}

// You need these models here — if they’re missing, Prisma won’t create the tables
model User {
  id       String @id
  username String @unique
  password String
  role     String
}

model Student {
  studentId  String @id
  firstName  String
  lastName   String
  middleName String?
  course     String
  yearLevel  String
  school     String
  status     String
  timeRecords TimeRecord[]
}

model TimeRecord {
  id        Int      @id @default(autoincrement())
  studentId String

  timeIn    DateTime?
  timeOut   DateTime?
  student   Student  @relation(fields: [studentId], references: [studentId], onDelete: Cascade)
}